rule condition_true
{
  condition:
  true
}
rule condition_false
{
  condition:
  false
}
rule just_filesize
{
  condition:
  (filesize > 0)
}
rule empty_strings_section
{
  condition:
  (filesize < 0xf4240)
}
rule single_string_no_meta
{
  strings:
  $a = "test" ascii
  condition:
  $a
}
rule meta_only_condition_true
{
  meta:
  author = "test"
  description = "minimal rule with metadata"
  version = 1
  is_test = true
  condition:
  true
}
rule multiple_tags : tag1 tag2 tag3
{
  condition:
  true
}