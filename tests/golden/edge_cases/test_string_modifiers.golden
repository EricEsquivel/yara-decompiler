rule xor_basic
{
  strings:
  $a = "secret" ascii xor
  condition:
  $a
}
rule combined_modifiers
{
  strings:
  $a = "test" nocase ascii wide
  $b = "data" ascii fullword
  $c = "info" nocase wide fullword
  condition:
  (($a or $b) or $c)
}
rule private_string
{
  strings:
  $a = "visible" ascii
  $b = "hidden" ascii private
  condition:
  ($a and $b)
}
rule wide_ascii
{
  strings:
  $a = "unicode" wide
  $b = "plain" ascii
  condition:
  ($a or $b)
}