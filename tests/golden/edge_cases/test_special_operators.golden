rule contains_operator
{
  condition:
  (("hello world" contains "world") and ("testing" contains "est"))
}
rule icontains_operator
{
  condition:
  ("Hello World" and ("WORLD" and ("TESTING" and "test")))
}
rule startswith_operator
{
  condition:
  ("hello world" and ("hello" and ("testing123" and "test")))
}
rule endswith_operator
{
  condition:
  ("hello world" and ("world" and ("testing123" and 123)))
}
rule iequals_operator
{
  condition:
  (("Hello" == "HELLO") and ("TeSt" == "test"))
}