import "pe"
import "math"
rule pe_basic
{
  condition:
  (pe.is_pe and (pe.number_of_sections > 0))
}
rule pe_sections
{
  condition:
  for any i in (0..(pe.number_of_sections - 1)) : ( (pe.sections[i].raw_data_size > 0) )
}
rule math_entropy
{
  condition:
  ((math.entropy(0, filesize) > 0) and (math.entropy(0, filesize) <= 8))
}
rule combined_modules
{
  condition:
  ((pe.is_pe and (math.entropy(0, filesize) > 6)) and (pe.number_of_sections >= 3))
}