rule global_detector
{
  strings:
  $a = "global_marker" ascii
  condition:
  $a
}
rule private_helper
{
  strings:
  $a = "helper_string" ascii
  condition:
  $a
}
rule uses_private : tag1
{
  condition:
  private_helper
}
rule private_global_combo
{
  strings:
  $a = "combo" ascii
  condition:
  $a
}