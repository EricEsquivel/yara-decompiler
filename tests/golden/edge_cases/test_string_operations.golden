rule string_count_basic
{
  strings:
  $a = "test" ascii
  condition:
  (((#a > 0) and (#a < 100)) and (#a >= 1))
}
rule string_count_comparison
{
  strings:
  $a = "one" ascii
  $b = "two" ascii
  condition:
  (((#a == #b) or (#a > #b)) or (#a < #b))
}
rule string_offset_basic
{
  strings:
  $a = "marker" ascii
  condition:
  ((@a[1] > 0) and (@a[1] < filesize))
}
rule string_offset_indexed
{
  strings:
  $a = "repeat" ascii
  condition:
  ((@a[1] > 0) and (@a[#a] < filesize))
}
rule string_at_position
{
  strings:
  $mz = "MZ" ascii
  $pe = "PE" ascii
  condition:
  ($mz at 0 or $pe at 128)
}
rule string_in_range
{
  strings:
  $a = "header" ascii
  condition:
  ($a in (0..1024) and $a in (0..filesize))
}
rule combined_string_ops
{
  strings:
  $a = "marker" ascii
  condition:
  ((#a > 0) and (@a[1] < 1000))
}