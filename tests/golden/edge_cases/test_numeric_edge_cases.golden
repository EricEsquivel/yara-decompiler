rule negative_integers
{
  condition:
  (((0 == 1) or (0 == 32768)) or (0 == 128))
}
rule hex_representations
{
  condition:
  (((0 == 4660) and (0 == 255)) and (uint32(0) == 0xcafebabe))
}
rule arithmetic_operations
{
  condition:
  (((((10 + 5) == 15) and ((20 - 8) == 12)) and ((6 * 7) == 42)) and ((17 % 5) == 2))
}
rule bitwise_operations
{
  condition:
  ((((((255 & 15) == 15) and ((240 | 15) == 255)) and ((255 ^ 170) == 85)) and ((1 << 4) == 16)) and ((256 >> 4) == 16))
}
rule comparison_chain
{
  condition:
  ((((((1 < 2) and (2 <= 2)) and (3 > 2)) and (3 >= 3)) and (4 != 5)) and (5 == 5))
}
rule filesize_arithmetic
{
  condition:
  ((filesize > 0) and (filesize < 0x7fffffff))
}